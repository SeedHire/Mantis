{
  "name": "mantis-vscode",
  "displayName": "Mantis — Codebase Intelligence",
  "description": "Local-first dependency graph, context bundler, and architecture linter for VS Code",
  "version": "0.1.0",
  "publisher": "mantis-dev",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Linters"],
  "icon": "icon.png",
  "keywords": ["dependency graph", "architecture", "LLM context", "code intelligence"],
  "activationEvents": ["onLanguage:typescript", "onLanguage:javascript", "onLanguage:python"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "mantis.init", "title": "Mantis: Initialize (index project)" },
      { "command": "mantis.findSymbol", "title": "Mantis: Find Symbol Usages" },
      { "command": "mantis.bundleContext", "title": "Mantis: Copy Context Bundle" },
      { "command": "mantis.showImpact", "title": "Mantis: Show Impact Analysis" },
      { "command": "mantis.openGraph", "title": "Mantis: Open Dependency Graph" },
      { "command": "mantis.runLint", "title": "Mantis: Run Architecture Lint" },
      { "command": "mantis.findDead", "title": "Mantis: Find Dead Code" }
    ],
    "viewsContainers": {
      "activitybar": [{
        "id": "mantis-sidebar",
        "title": "Mantis",
        "icon": "$(symbol-structure)"
      }]
    },
    "views": {
      "mantis-sidebar": [
        { "id": "mantis.dependencyTree", "name": "Dependencies" },
        { "id": "mantis.lintResults", "name": "Lint Results" }
      ]
    },
    "configuration": {
      "title": "Mantis",
      "properties": {
        "mantis.binaryPath": {
          "type": "string",
          "default": "mantis",
          "description": "Path to the mantis binary (default: 'mantis' from PATH)"
        },
        "mantis.autoLint": {
          "type": "boolean",
          "default": true,
          "description": "Run architecture lint automatically on save"
        },
        "mantis.contextTokens": {
          "type": "number",
          "default": 8000,
          "description": "Default token budget for context bundles"
        },
        "mantis.contextDepth": {
          "type": "number",
          "default": 3,
          "description": "Default import depth for context bundles"
        }
      }
    },
    "menus": {
      "editor/context": [
        { "command": "mantis.findSymbol", "when": "editorHasSelection", "group": "mantis@1" },
        { "command": "mantis.bundleContext", "when": "editorHasSelection", "group": "mantis@2" },
        { "command": "mantis.showImpact", "group": "mantis@3" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
